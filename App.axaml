<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="MyAvaloniaApp.App"
             RequestedThemeVariant="Light">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="AppBg" Color="#f5f6f8" />
          <SolidColorBrush x:Key="SurfaceBg" Color="#ffffff" />
          <SolidColorBrush x:Key="PanelBg" Color="#f7f7f9" />
          <SolidColorBrush x:Key="SubPanelBg" Color="#ffffff" />
          <SolidColorBrush x:Key="HeaderBg" Color="#ffffff" />

          <SolidColorBrush x:Key="Border" Color="#dfe2e8" />
          <SolidColorBrush x:Key="BorderSoft" Color="#e1e2e5" />

          <SolidColorBrush x:Key="TextPrimary" Color="#1f232b" />
          <SolidColorBrush x:Key="TextSecondary" Color="#6f7680" />
          <SolidColorBrush x:Key="Icon" Color="#3b4048" />

          <SolidColorBrush x:Key="HoverBg" Color="#edf1f7" />
          <SolidColorBrush x:Key="Accent" Color="#86a7d1" />
          <SolidColorBrush x:Key="AccentSoft" Color="#dce8f6" />
          <SolidColorBrush x:Key="Danger" Color="#d23f3f" />

          <!-- Fluent theme (TextBox/ComboBox/etc.) default state resources -->
          <SolidColorBrush x:Key="TextControlBackground" Color="#ffffff" />
          <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#edf1f7" />
          <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#ffffff" />
          <SolidColorBrush x:Key="TextControlBorderBrush" Color="#e1e2e5" />
          <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#dfe2e8" />
          <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#86a7d1" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="AppBg" Color="#0f1116" />
          <SolidColorBrush x:Key="SurfaceBg" Color="#161a22" />
          <SolidColorBrush x:Key="PanelBg" Color="#121621" />
          <SolidColorBrush x:Key="SubPanelBg" Color="#1a2030" />
          <SolidColorBrush x:Key="HeaderBg" Color="#161a22" />

          <SolidColorBrush x:Key="Border" Color="#2b3242" />
          <SolidColorBrush x:Key="BorderSoft" Color="#2b3242" />

          <SolidColorBrush x:Key="TextPrimary" Color="#e8ecf4" />
          <SolidColorBrush x:Key="TextSecondary" Color="#a6afbf" />
          <SolidColorBrush x:Key="Icon" Color="#c9d1df" />

          <SolidColorBrush x:Key="HoverBg" Color="#222d40" />
          <SolidColorBrush x:Key="Accent" Color="#5b8bd1" />
          <SolidColorBrush x:Key="AccentSoft" Color="#263d5f" />
          <SolidColorBrush x:Key="Danger" Color="#ff6b6b" />

          <!-- Fluent theme (TextBox/ComboBox/etc.) default state resources -->
          <SolidColorBrush x:Key="TextControlBackground" Color="#1a2030" />
          <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#222d40" />
          <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1a2030" />
          <SolidColorBrush x:Key="TextControlBorderBrush" Color="#2b3242" />
          <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#2b3242" />
          <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#5b8bd1" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>
  <Application.Styles>
    <!-- App theme is controlled via RequestedThemeVariant (toggle in UI). -->
    <fluent:FluentTheme />

    <!-- Override Fluent defaults to avoid "black flash" on hover/focus in dark mode. -->
    <Style Selector="Button">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>

    <Style Selector="ToggleButton">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="ToggleButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    </Style>

    <Style Selector="ComboBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
    </Style>
    <Style Selector="ComboBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource AccentSoft}" />
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="CheckBox:pointerover">
      <Setter Property="Background" Value="{DynamicResource HoverBg}" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}" />
      <Setter Property="SelectionBrush" Value="{DynamicResource AccentSoft}" />
      <Setter Property="SelectionForegroundBrush" Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="ComboBox:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
    </Style>
    <Style Selector="ComboBox:focus">
      <Setter Property="Background" Value="{DynamicResource SurfaceBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
  </Application.Styles>
</Application>
