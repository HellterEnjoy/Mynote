<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MyAvaloniaApp.Views.ProjectPickerWindow"
        Width="860" Height="540"
        Title="Mynote - Open Project"
        Background="{DynamicResource AppBg}">
  <Window.Styles>
    <Style Selector="Border.app-shell">
      <Setter Property="BoxShadow" Value="0 16 44 0 #22000000" />
    </Style>
    <Style Selector="Border.app-shell:pointerover">
      <Setter Property="BoxShadow" Value="0 18 52 0 #2A000000, 0 0 22 0 #14FFFFFF" />
    </Style>
  </Window.Styles>
  <Grid Margin="18" ColumnDefinitions="340,*" RowDefinitions="Auto,*">
    <TextBlock Grid.ColumnSpan="2"
               Text="Choose a project folder (like an Obsidian vault)"
               FontSize="18"
               FontWeight="SemiBold"
               Foreground="{DynamicResource TextPrimary}"
               Margin="0,0,0,14"/>

    <Border Grid.Row="1"
            Classes="app-shell"
            Background="{DynamicResource SurfaceBg}"
            CornerRadius="10"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="14"
            Margin="0,0,14,0">
      <Grid RowDefinitions="Auto,* ,Auto" >
        <TextBlock Text="Recent Projects" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Projects}"
                 SelectedItem="{Binding SelectedProject}"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border CornerRadius="8" Padding="10" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" Background="{DynamicResource SurfaceBg}" Margin="0,0,0,10">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                  <TextBlock Text="{Binding RootPath}" FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
          <Button Click="Remove_Click"
                  Padding="12,10"
                  Background="{DynamicResource SurfaceBg}"
                  BorderBrush="{DynamicResource BorderSoft}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Content="Remove"/>
          <Button Click="OpenSelected_Click"
                  Padding="12,10"
                  Background="{DynamicResource TextPrimary}"
                  Foreground="{DynamicResource SurfaceBg}"
                  BorderThickness="0"
                  CornerRadius="8"
                  Content="Open"/>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Column="1"
            Grid.Row="1"
            Classes="app-shell"
            Background="{DynamicResource SurfaceBg}"
            CornerRadius="10"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="14">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="*,Auto">
        <TextBlock Grid.ColumnSpan="2" Text="Create New Project" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="Name" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
        <TextBox Grid.Row="2" Grid.ColumnSpan="2"
                 Text="{Binding NewProjectName, Mode=TwoWay}"
                 Watermark="Project name"
                 Padding="10"
                 CornerRadius="8"
                 BorderBrush="{DynamicResource BorderSoft}"
                 BorderThickness="1"
                 Background="{DynamicResource SurfaceBg}"
                 Foreground="{DynamicResource TextPrimary}"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="Folder" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,12,0,6"/>
        <TextBox Grid.Row="4"
                 Text="{Binding NewProjectPath, Mode=TwoWay}"
                 Watermark="Choose a folder for project data"
                 Padding="10"
                 CornerRadius="8"
                 BorderBrush="{DynamicResource BorderSoft}"
                 BorderThickness="1"
                 Background="{DynamicResource SurfaceBg}"
                 Foreground="{DynamicResource TextPrimary}"/>
        <Button Grid.Row="4" Grid.Column="1"
                Click="BrowseNewPath_Click"
                Padding="12,10"
                Margin="10,0,0,0"
                Background="{DynamicResource SurfaceBg}"
                BorderBrush="{DynamicResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Content="Browse"/>

        <CheckBox Grid.Row="5"
                  Grid.ColumnSpan="2"
                  IsChecked="{Binding IsPasswordEnabled, Mode=TwoWay}"
                  Foreground="{DynamicResource TextPrimary}"
                  Margin="0,14,0,0"
                  Content="Protect project with password (recommended)"/>

        <TextBox Grid.Row="6" Grid.ColumnSpan="2"
                 IsVisible="{Binding IsPasswordEnabled}"
                 Text="{Binding NewProjectPassword, Mode=TwoWay}"
                 PasswordChar="*"
                 Watermark="Password"
                 Padding="10"
                 CornerRadius="8"
                 BorderBrush="{DynamicResource BorderSoft}"
                 BorderThickness="1"
                 Background="{DynamicResource SurfaceBg}"
                 Foreground="{DynamicResource TextPrimary}"
                 Margin="0,10,0,0"/>

        <TextBox Grid.Row="7" Grid.ColumnSpan="2"
                 IsVisible="{Binding IsPasswordEnabled}"
                 Text="{Binding NewProjectPasswordConfirm, Mode=TwoWay}"
                 PasswordChar="*"
                 Watermark="Confirm password"
                 Padding="10"
                 CornerRadius="8"
                 BorderBrush="{DynamicResource BorderSoft}"
                 BorderThickness="1"
                 Background="{DynamicResource SurfaceBg}"
                 Foreground="{DynamicResource TextPrimary}"
                 Margin="0,10,0,0"/>

        <TextBox Grid.Row="8" Grid.ColumnSpan="2"
                 IsVisible="{Binding IsPasswordEnabled}"
                 Text="{Binding NewProjectPasswordHint, Mode=TwoWay}"
                 Watermark="Hint (optional)"
                 Padding="10"
                 CornerRadius="8"
                 BorderBrush="{DynamicResource BorderSoft}"
                 BorderThickness="1"
                 Background="{DynamicResource SurfaceBg}"
                 Foreground="{DynamicResource TextPrimary}"
                 Margin="0,10,0,0"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
          <Button Click="OpenExisting_Click"
                  Padding="12,10"
                  Background="{DynamicResource SurfaceBg}"
                  BorderBrush="{DynamicResource BorderSoft}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Content="Open Existing Folder"/>
          <Button Click="Create_Click"
                  Padding="12,10"
                  Background="{DynamicResource TextPrimary}"
                  Foreground="{DynamicResource SurfaceBg}"
                  BorderThickness="0"
                  CornerRadius="8"
                  Content="Create &amp; Open"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
